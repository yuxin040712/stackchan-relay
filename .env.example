# Copy to .env and fill in a long random value, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"
STACKCHAN_TOKEN=changeme

STACKCHAN_HOST=127.0.0.1
STACKCHAN_PORT=8011

# Seconds /poll waits for a new command before returning empty.
STACKCHAN_POLL_TIMEOUT=25

# Seconds since last /poll before the robot is considered offline.
STACKCHAN_ONLINE_THRESHOLD=30
